---
import Layout from '../layouts/Layout.astro';
import { business } from '../data/business';
---

<Layout
  title="Broker hipotecario Castellón | BHC — Comparamos +30 bancos por ti"
  description={business.description}
>
  <section class="bg-bg-soft">
    <div class="max-w-3xl mx-auto px-4 py-24 text-center">
      <div class="inline-block bg-primary-600 text-white text-2xl font-extrabold w-16 h-16 leading-[4rem] rounded-xl">BHC</div>
      <h1 class="mt-6">Phase 1 OK</h1>
      <p class="mt-3 text-text-muted">Layout + Navigation + Footer + Schema cargados. Próximo: Phase 2 (Hero, servicios, FAQ, home completa).</p>
    </div>
  </section>
</Layout>
